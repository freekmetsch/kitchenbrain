# Keukenbrein — plain-value template for self-hosting / forking.
# Copy to `.env` (or set these as your platform's env vars) and fill in real values.

# --- Required ---

# OpenRouter API key. Powers chat and all background AI jobs (GLM models by
# default). Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Login users, seeded/updated at boot. Format: "name:password,name:password"
# (a password may contain ':' but never ','). Changing a user's password from
# Settings takes ownership of it afterward — a redeploy no longer overwrites it.
HOUSEHOLD_USERS=alice:changeme,bob:changeme

# --- Server (read by @sveltejs/adapter-node) ---
PORT=5173
ORIGIN=http://localhost:5173

# --- Storage ---

# SQLite file path. A persistent volume mount (e.g. Railway, Fly.io) should
# point this at a path on that volume, not the app's own filesystem.
DATABASE_URL=./dev.db

# Where uploaded recipe photos are stored on disk. Same persistent-volume advice
# as DATABASE_URL applies.
RECIPE_IMAGES_DIR=./data/recipe_images

# Where the Albert Heijn connect flow stores its session tokens. Never put a
# real token here directly — this file is written by Settings -> Connections.
AH_TOKEN_FILE=./ah_tokens.json

# Set to '1' only when Litestream owns WAL checkpointing (continuous backup of
# the SQLite file to object storage). Leave unset for plain local SQLite.
# LITESTREAM_ENABLED=1

# --- Spend caps (EUR/day, one line each for chat vs. background AI jobs) ---
PWA_DAILY_EUR_CAP=0.50
PWA_BACKGROUND_DAILY_EUR_CAP=0.50

# --- Optional: model overrides ---
# Defaults are GLM models via OpenRouter. Once the app is running, all four are
# also editable from Settings -> AI / Advanced; an in-app change takes
# precedence over these vars until reset from that same panel.
# CHAT_MODEL=z-ai/glm-5
# CHAT_FALLBACK_MODEL=z-ai/glm-5.2
# VISION_MODEL=z-ai/glm-4.6v
# BACKGROUND_MODEL=z-ai/glm-4.7-flash

# --- Optional: currency ---
# USD_TO_EUR=0.92

# --- Optional: dormant Anthropic rollback ---
# Only needed if you point one of the *_MODEL vars above at a claude-*/anthropic/*
# id — everything else runs entirely on OPENROUTER_API_KEY.
# ANTHROPIC_API_KEY=sk-ant-...
